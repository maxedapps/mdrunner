{
  "name": "mdrunner",
  "version": "0.0.0",
  "private": true,
  "description": "Render Markdown as polished, self-contained HTML and open it in the default browser.",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:coverage": "bun test --coverage tests/unit",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src tests",
    "format": "oxfmt --write . '!**/.plans/**' '!**/.subagents/**'",
    "format:check": "oxfmt --check . '!**/.plans/**' '!**/.subagents/**'",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test:unit"
  },
  "dependencies": {
    "beautiful-mermaid": "1.1.3",
    "fast-xml-parser": "5.10.1",
    "satteri": "0.9.5",
    "satteri-expressive-code": "0.1.18"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "7.0.2"
  },
  "packageManager": "bun@1.3.14"
}
