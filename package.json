{
  "name": "mdrunner",
  "version": "0.0.0",
  "private": true,
  "description": "Render Markdown as polished, self-contained HTML and open it in the default browser.",
  "type": "module",
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun scripts/build.ts",
    "build:macos-arm64": "bun install --frozen-lockfile --os=darwin --cpu=arm64 && bun scripts/build.ts bun-darwin-arm64",
    "build:macos-x64": "bun install --frozen-lockfile --os=darwin --cpu=x64 && bun scripts/build.ts bun-darwin-x64",
    "build:linux-arm64": "bun install --frozen-lockfile --os=linux --cpu=arm64 && bun scripts/build.ts bun-linux-arm64",
    "build:linux-arm64-musl": "bun install --frozen-lockfile --os=linux --cpu=arm64 && bun scripts/build.ts bun-linux-arm64-musl",
    "build:linux-x64": "bun install --frozen-lockfile --os=linux --cpu=x64 && bun scripts/build.ts bun-linux-x64",
    "build:linux-x64-musl": "bun install --frozen-lockfile --os=linux --cpu=x64 && bun scripts/build.ts bun-linux-x64-musl",
    "build:windows-arm64": "bun install --frozen-lockfile --os=win32 --cpu=arm64 && bun scripts/build.ts bun-windows-arm64",
    "build:windows-x64": "bun install --frozen-lockfile --os=win32 --cpu=x64 && bun scripts/build.ts bun-windows-x64",
    "build:all": "bun install --frozen-lockfile --os='*' --cpu='*' && bun scripts/build.ts --all",
    "test": "bun test tests/unit tests/integration tests/security tests/cli",
    "test:standalone": "bun test --timeout 300000 tests/standalone/standalone.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src scripts tests",
    "format": "oxfmt --write . '!**/.plans/**' '!**/.subagents/**'",
    "format:check": "oxfmt --check . '!**/.plans/**' '!**/.subagents/**'",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "beautiful-mermaid": "1.1.3",
    "fast-xml-parser": "5.10.1",
    "satteri": "0.9.5",
    "satteri-expressive-code": "0.1.18"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "7.0.2"
  },
  "packageManager": "bun@1.3.14"
}
